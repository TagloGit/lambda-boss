<Window x:Class="LambdaBoss.UI.LambdaPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lambda Boss"
        Width="480" Height="380"
        WindowStyle="ToolWindow"
        ShowInTaskbar="True"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        Background="#1e1e1e">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Mode indicator -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock x:Name="LibraryModeLabel"
                       Text="Libraries"
                       FontSize="12"
                       FontWeight="Bold"
                       Foreground="#dcdcaa"
                       Cursor="Hand"
                       MouseLeftButtonDown="LibraryModeLabel_Click" />
            <TextBlock Text="  ·  "
                       FontSize="12"
                       Foreground="#555555" />
            <TextBlock x:Name="SearchModeLabel"
                       Text="Search"
                       FontSize="12"
                       Foreground="#808080"
                       Cursor="Hand"
                       MouseLeftButtonDown="SearchModeLabel_Click" />
            <TextBlock Text="  ·  "
                       FontSize="12"
                       Foreground="#555555" />
            <TextBlock x:Name="CommandsModeLabel"
                       Text="Commands"
                       FontSize="12"
                       Foreground="#808080"
                       Cursor="Hand"
                       MouseLeftButtonDown="CommandsModeLabel_Click" />
        </StackPanel>

        <!-- Search box -->
        <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Margin="0,0,0,6"
                 Padding="6,4"
                 FontSize="14"
                 Background="#2d2d2d"
                 Foreground="#cccccc"
                 CaretBrush="#cccccc"
                 BorderBrush="#3e3e3e"
                 BorderThickness="1"
                 TextChanged="SearchBox_TextChanged" />

        <!-- Library list (library mode) -->
        <ListBox x:Name="LibraryList"
                 Grid.Row="2"
                 Background="#252526"
                 Foreground="#cccccc"
                 BorderBrush="#3e3e3e"
                 BorderThickness="1"
                 FontFamily="Consolas"
                 FontSize="13"
                 SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4,3">
                        <StackPanel Orientation="Horizontal">
                            <!-- ReSharper disable Xaml.BindingWithContextNotResolved -->
                            <TextBlock Text="{Binding SourceIcon}" Foreground="#cccccc" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" Foreground="#dcdcaa" />
                            <TextBlock Text="  " />
                            <TextBlock Text="{Binding LambdaCountLabel}" Foreground="#569cd6" FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="  " />
                            <TextBlock Text="{Binding LoadedLabel}" Foreground="#608b4e" FontSize="11"
                                       VerticalAlignment="Center" />
                            <!-- ReSharper restore Xaml.BindingWithContextNotResolved -->
                        </StackPanel>
                        <!-- ReSharper disable Xaml.BindingWithContextNotResolved -->
                        <TextBlock Text="{Binding Description}" Foreground="#808080" FontSize="11"
                                   TextTrimming="CharacterEllipsis" />
                        <!-- ReSharper restore Xaml.BindingWithContextNotResolved -->
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Lambda list (search mode) -->
        <ListBox x:Name="LambdaList"
                 Grid.Row="2"
                 Background="#252526"
                 Foreground="#cccccc"
                 BorderBrush="#3e3e3e"
                 BorderThickness="1"
                 FontFamily="Consolas"
                 FontSize="13"
                 SelectionMode="Single"
                 Visibility="Collapsed">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                    <Grid Margin="4,2"
                          ToolTip="{Binding DescriptionToolTip}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- ReSharper disable Xaml.BindingWithContextNotResolved -->
                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold"
                                   Foreground="#dcdcaa" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Description}" Foreground="#808080"
                                   FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" Margin="8,0,8,0" />
                        <TextBlock Grid.Column="2" Text="{Binding LibraryLabel}" Foreground="#569cd6"
                                   FontSize="11" VerticalAlignment="Center" />
                        <!-- ReSharper restore Xaml.BindingWithContextNotResolved -->
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Commands list (commands mode) -->
        <ListBox x:Name="CommandsList"
                 Grid.Row="2"
                 Background="#252526"
                 Foreground="#cccccc"
                 BorderBrush="#3e3e3e"
                 BorderThickness="1"
                 FontFamily="Consolas"
                 FontSize="13"
                 SelectionMode="Single"
                 Visibility="Collapsed">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                    <Grid Margin="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- ReSharper disable Xaml.BindingWithContextNotResolved -->
                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold"
                                   Foreground="#dcdcaa" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Description}" Foreground="#808080"
                                   FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                        <!-- ReSharper restore Xaml.BindingWithContextNotResolved -->
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Prefix prompt (shown when loading) -->
        <Border x:Name="PrefixPanel"
                Grid.Row="3"
                Margin="0,6,0,0"
                Padding="6,4"
                Background="#2d2d2d"
                BorderBrush="#569cd6"
                BorderThickness="1"
                CornerRadius="2"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Prefix: "
                           Foreground="#cccccc"
                           FontSize="13"
                           VerticalAlignment="Center" />
                <TextBox x:Name="PrefixBox"
                         Width="120"
                         Padding="4,2"
                         FontSize="13"
                         FontFamily="Consolas"
                         Background="#1e1e1e"
                         Foreground="#dcdcaa"
                         CaretBrush="#dcdcaa"
                         BorderBrush="#3e3e3e"
                         BorderThickness="1" />
                <TextBlock Text="  Enter to load · Escape to cancel"
                           Foreground="#808080"
                           FontSize="11"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Margin="0,4,0,0"
                   Foreground="#808080"
                   FontSize="11"
                   Text="↑↓ navigate · Enter load · Tab switch · Esc close" />
    </Grid>
</Window>