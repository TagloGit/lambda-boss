/*  FUNCTION NAME:      AddN
    DESCRIPTION:*//**Adds N to a number.*/
/*  REVISIONS:          Date        Developer   Description
                        2026-04-09  Tim Jacks   Initial version
*/
AddN = LAMBDA(
//  Parameter Declarations
    x,
    n,
//  Help
    LET(Help, TEXTSPLIT(
                "FUNCTION:      →AddN(x, n)¶" &
                "DESCRIPTION:   →Adds N to a number.¶" &
                "VERSION:       →Apr 09 2026¶" &
                "PARAMETERS:    →¶" &
                "   x              →(Required) The base number.¶" &
                "   n              →(Required) The number to add.¶" &
                "EXAMPLE:       →¶" &
                "Formula        →=AddN(5, 3)¶" &
                "Result         →8",
                "→", "¶"
                ),
    //  Procedure
        result, x + n,
        IF(Help?, Help, result)
)
);
